APP_DATA_DIR=.data
EMBEDDING_PROVIDER=local_hash
EMBEDDING_DIMENSIONS=384
LLM_PROVIDER=extractive
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
TOP_K=5
CHAT_CONTEXT_MESSAGES=12
FULL_CONTEXT_MAX_CHARS=24000
SYSTEM_PROMPT=
RAG_TEMPLATE=

# External OCR extraction service (ocr_detection_worker_updated /extract).
# When OCR_EXTRACTION_URL is set, every uploaded file is extracted through the
# VLM OCR pipeline instead of native pypdf/docx2txt parsing.
OCR_EXTRACTION_URL=
# OCR_EXTRACTION_URL=http://localhost:8200/extract
OCR_EXTRACTION_FORMAT=markdown
OCR_EXTRACTION_TIMEOUT=300
OCR_FALLBACK_NATIVE=true
